{
  "name": "@replaystack/sdk",
  "version": "1.0.1",
  "description": "Official ReplayStack SDK for Node.js 18+: capture HTTP requests, responses, exceptions, stack frames, and breadcrumbs; ship them to ReplayStack for debugging, replay, and dashboards. First-class Express, Next.js, and NestJS integrations.",
  "keywords": [
    "replaystack",
    "tracereplay",
    "observability",
    "debugging",
    "error-tracking",
    "exceptions",
    "stack-trace",
    "api-monitoring",
    "event-replay",
    "replay",
    "backend",
    "nodejs",
    "sdk",
    "typescript",
    "express",
    "nextjs",
    "nestjs"
  ],
  "author": "ReplayStack",
  "license": "MIT",
  "homepage": "https://replaystack.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AliJabbar034/replaystack-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/AliJabbar034/replaystack-sdk/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:verify": "npm run lint && npm run format:check && npm run test && npm run test:typecheck && npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:dry": "npm publish --dry-run",
    "publish:npm": "npm publish"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "express": ">=4.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^10.3.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "default": "./dist/nextjs.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "default": "./dist/nestjs.js"
    }
  }
}
